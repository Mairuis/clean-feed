{
  "name": "clean-feed",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e:llm": "CLEANFEED_RUN_LLM_E2E=1 vitest run src/e2e/llm.e2e.test.ts --testTimeout=45000",
    "validate": "npm run check && npm run test && npm run build && node scripts/validate-manifest.mjs && node scripts/validate-manifest.mjs release/clean-feed/manifest.json"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "ai": "^6.0.168",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
